[["Map",1,2,34,35,42,43],"blog",["Map",3,4],"first-post",{"id":3,"data":5,"body":16,"filePath":17,"digest":18,"rendered":19},{"title":6,"description":7,"pubDate":8,"tags":9,"heroImage":12,"heroAlt":13,"draft":14,"featured":15},"第一篇沉浸式博客","记录一次关于视觉、空间和网页体验的思考。",["Date","2026-01-01T00:00:00.000Z"],[10,11,1],"design","frontend","/images/aurora-sky.svg","星空与极光交织的沉浸式视觉背景",false,true,"欢迎来到这个个人博客。这里可以记录创作、技术、生活观察，以及那些一闪而过却值得留下的灵感。\r\n\r\n这个站点的第一版采用静态博客结构。你只需要在 `src/content/blog/` 下新增一个文件夹，放入 `index.md`，填写标题、摘要、日期和标签，就可以发布一篇新文章。\r\n\r\n## 为什么做一个沉浸式博客\r\n\r\n普通博客强调内容效率，而沉浸式博客更像一个安静的私人展厅。背景、光影、文字和交互共同构成氛围，让阅读从“浏览信息”变成“进入一个空间”。\r\n\r\n## 后续可以写什么\r\n\r\n- 设计过程记录。\r\n- 前端技术笔记。\r\n- 作品复盘。\r\n- 日常灵感与摄影观察。","src/content/blog/first-post/index.md","aa806ce7de2f381d",{"html":20,"metadata":21},"\u003Cp>欢迎来到这个个人博客。这里可以记录创作、技术、生活观察，以及那些一闪而过却值得留下的灵感。\u003C/p>\n\u003Cp>这个站点的第一版采用静态博客结构。你只需要在 \u003Ccode>src/content/blog/\u003C/code> 下新增一个文件夹，放入 \u003Ccode>index.md\u003C/code>，填写标题、摘要、日期和标签，就可以发布一篇新文章。\u003C/p>\n\u003Ch2 id=\"为什么做一个沉浸式博客\">为什么做一个沉浸式博客\u003C/h2>\n\u003Cp>普通博客强调内容效率，而沉浸式博客更像一个安静的私人展厅。背景、光影、文字和交互共同构成氛围，让阅读从“浏览信息”变成“进入一个空间”。\u003C/p>\n\u003Ch2 id=\"后续可以写什么\">后续可以写什么\u003C/h2>\n\u003Cul>\n\u003Cli>设计过程记录。\u003C/li>\n\u003Cli>前端技术笔记。\u003C/li>\n\u003Cli>作品复盘。\u003C/li>\n\u003Cli>日常灵感与摄影观察。\u003C/li>\n\u003C/ul>",{"headings":22,"localImagePaths":28,"remoteImagePaths":29,"frontmatter":30,"imagePaths":33},[23,26],{"depth":24,"slug":25,"text":25},2,"为什么做一个沉浸式博客",{"depth":24,"slug":27,"text":27},"后续可以写什么",[],[],{"title":6,"description":7,"pubDate":31,"tags":32,"heroImage":12,"heroAlt":13,"draft":14,"featured":15},["Date","2026-01-01T00:00:00.000Z"],[10,11,1],[],"meta::meta",["Map",36,37,38,39,40,41],"astro-config-digest","{\"root\":{},\"srcDir\":{},\"publicDir\":{},\"outDir\":{},\"cacheDir\":{},\"site\":\"https://your-domain.com\",\"compressHTML\":true,\"base\":\"/\",\"trailingSlash\":\"always\",\"output\":\"static\",\"scopedStyleStrategy\":\"attribute\",\"build\":{\"format\":\"directory\",\"client\":{},\"server\":{},\"assets\":\"_astro\",\"serverEntry\":\"entry.mjs\",\"redirects\":true,\"inlineStylesheets\":\"auto\",\"concurrency\":1},\"server\":{\"open\":false,\"host\":false,\"port\":4321,\"allowedHosts\":[]},\"redirects\":{},\"image\":{\"endpoint\":{\"route\":\"/_image/\"},\"service\":{\"entrypoint\":\"astro/assets/services/sharp\",\"config\":{}},\"dangerouslyProcessSVG\":false,\"domains\":[],\"remotePatterns\":[],\"responsiveStyles\":false},\"devToolbar\":{\"enabled\":true},\"markdown\":{\"syntaxHighlight\":{\"type\":\"shiki\",\"excludeLangs\":[\"math\"]},\"shikiConfig\":{\"langs\":[],\"langAlias\":{},\"theme\":\"github-dark\",\"themes\":{},\"wrap\":false,\"transformers\":[]},\"remarkPlugins\":[],\"rehypePlugins\":[],\"remarkRehype\":{},\"processor\":{\"name\":\"unified\",\"options\":{\"remarkPlugins\":[],\"rehypePlugins\":[],\"remarkRehype\":{}}}},\"security\":{\"checkOrigin\":true,\"allowedDomains\":[],\"csp\":false,\"actionBodySizeLimit\":1048576,\"serverIslandBodySizeLimit\":1048576},\"env\":{\"schema\":{},\"validateSecrets\":false},\"prerenderConflictBehavior\":\"warn\",\"experimental\":{\"advancedRouting\":false,\"clientPrerender\":false,\"contentIntellisense\":false,\"chromeDevtoolsWorkspace\":false,\"rustCompiler\":false,\"queuedRendering\":{\"enabled\":false}},\"legacy\":{\"collectionsBackwardsCompat\":false}}","astro-version","6.4.8","content-config-digest","7bbc0b0fc7898dd5","projects",["Map",44,45],"first-project",{"id":44,"data":46,"body":59,"filePath":60,"digest":61,"rendered":62},{"title":47,"description":48,"pubDate":49,"role":50,"stack":51,"coverImage":55,"coverAlt":56,"demoUrl":57,"repoUrl":58,"draft":14,"featured":15},"星幕个人主页实验","一个以全屏视觉背景、玻璃拟态面板和极简排版构成的个人主页概念作品。",["Date","2026-01-02T00:00:00.000Z"],"设计 / 前端开发",[52,53,54],"Astro","CSS","Markdown","/images/project-nebula.svg","带有星云渐变与玻璃面板的作品展示图","https://example.com","https://github.com/your-name/immersive-blog","这个作品用于探索“个人网站能否像一张电影海报一样打开”。页面结构尽量克制，让背景承担情绪，文字与按钮只作为漂浮在画面上的轻量引导。\r\n\r\n## 设计思路\r\n\r\n首屏使用大面积视觉背景，信息放在屏幕中下部，让顶部留白成为画面的一部分。玻璃面板负责保证文字可读，同时不破坏背景的沉浸感。\r\n\r\n## 技术实现\r\n\r\n页面基于 Astro 静态生成，内容由 Markdown 管理。视觉层主要依靠 CSS 变量、渐变、模糊、阴影和轻量交互动效完成。","src/content/projects/first-project/index.md","5c66de2009644df0",{"html":63,"metadata":64},"\u003Cp>这个作品用于探索“个人网站能否像一张电影海报一样打开”。页面结构尽量克制，让背景承担情绪，文字与按钮只作为漂浮在画面上的轻量引导。\u003C/p>\n\u003Ch2 id=\"设计思路\">设计思路\u003C/h2>\n\u003Cp>首屏使用大面积视觉背景，信息放在屏幕中下部，让顶部留白成为画面的一部分。玻璃面板负责保证文字可读，同时不破坏背景的沉浸感。\u003C/p>\n\u003Ch2 id=\"技术实现\">技术实现\u003C/h2>\n\u003Cp>页面基于 Astro 静态生成，内容由 Markdown 管理。视觉层主要依靠 CSS 变量、渐变、模糊、阴影和轻量交互动效完成。\u003C/p>",{"headings":65,"localImagePaths":70,"remoteImagePaths":71,"frontmatter":72,"imagePaths":75},[66,68],{"depth":24,"slug":67,"text":67},"设计思路",{"depth":24,"slug":69,"text":69},"技术实现",[],[],{"title":47,"description":48,"pubDate":73,"role":50,"stack":74,"coverImage":55,"coverAlt":56,"demoUrl":57,"repoUrl":58,"draft":14,"featured":15},["Date","2026-01-02T00:00:00.000Z"],[52,53,54],[]]