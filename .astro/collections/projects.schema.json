{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "pubDate": {
      "type": "string",
      "format": "date-time"
    },
    "role": {
      "type": "string"
    },
    "stack": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "coverImage": {
      "type": "string"
    },
    "coverAlt": {
      "type": "string"
    },
    "demoUrl": {
      "type": "string",
      "format": "uri"
    },
    "repoUrl": {
      "type": "string",
      "format": "uri"
    },
    "draft": {
      "default": false,
      "type": "boolean"
    },
    "featured": {
      "default": false,
      "type": "boolean"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "description",
    "pubDate",
    "role"
  ]
}