---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import GlassPanel from '../components/GlassPanel.astro';
import Prose from '../components/Prose.astro';
import { SITE } from '../site.config';
import { formatDate } from '../utils/content';

type Props = {
  project: CollectionEntry<'projects'>;
  jsonLd: Record<string, unknown>;
};

const { project, jsonLd } = Astro.props;
const image = project.data.coverImage ?? SITE.defaultImage;
---

<BaseLayout title={`${project.data.title} | ${SITE.name}`} description={project.data.description} image={image} type="article" jsonLd={jsonLd} class="project-detail-page">
  <section class="detail-hero">
    <div class="detail-bg parallax-layer" style={`--detail-image: url('${image}')`}></div>
    <div class="detail-shade"></div>
    <div class="page-shell detail-hero__content">
      <GlassPanel class="detail-title">
        <p class="eyebrow">{project.data.role} · {formatDate(project.data.pubDate)}</p>
        <h1>{project.data.title}</h1>
        <p>{project.data.description}</p>
        <div class="stack-list">
          {project.data.stack.map((item) => <span>{item}</span>)}
        </div>
        <div class="detail-actions">
          {project.data.demoUrl && <a class="button button--primary" href={project.data.demoUrl}>查看演示</a>}
          {project.data.repoUrl && <a class="button button--ghost" href={project.data.repoUrl}>代码仓库</a>}
        </div>
      </GlassPanel>
    </div>
  </section>
  <article class="page-shell article-shell" data-reveal>
    <Prose>
      <slot />
    </Prose>
    <p class="back-link"><a href="/projects/">返回作品列表</a></p>
  </article>
</BaseLayout>
