---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroVisual from '../components/HeroVisual.astro';
import { SITE } from '../site.config';
---

<BaseLayout title={SITE.title} description={SITE.description}>
  <HeroVisual
    eyebrow=""
    title="Satone"
    subtitle="沢山聽"
    video={`${import.meta.env.BASE_URL}videos/hero-wallpaper.mp4`}
    extendBg={`${import.meta.env.BASE_URL}images/hero-extend.jpg`}
  />
</BaseLayout>
