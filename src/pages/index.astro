---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroVisual from '../components/HeroVisual.astro';
import { SITE } from '../site.config';

const base = import.meta.env.BASE_URL || '/Satone-blog/';
---

<BaseLayout title={SITE.title} description={SITE.description}>
  <HeroVisual
    eyebrow=""
    title="Satone"
    subtitle="沢山聽"
    video={`${base}videos/hero-wallpaper.mp4`}
    extendBg={`${base}images/hero-extend.jpg`}
  />
</BaseLayout>
